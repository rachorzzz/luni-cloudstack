# WireGuard client config for {{ item.name }}
# Generated by Ansible — connect to {{ inventory_hostname }}
# Import with: wg-quick up /path/to/this/file

[Interface]
Address    = {{ item.wg_ip }}/32
PrivateKey = {{ wg_client_keys[item.name].private }}
DNS        = 213.133.100.100

[Peer]
PublicKey           = {{ wg_public_key }}
Endpoint            = {{ wg_endpoint }}:{{ wg_port }}
AllowedIPs          = 172.16.100.0/24, 172.16.102.0/24
PersistentKeepalive = {{ wg_keepalive }}
