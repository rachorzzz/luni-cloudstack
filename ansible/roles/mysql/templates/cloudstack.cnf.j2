# Managed by Ansible — CloudStack MySQL tuning
[mysqld]
innodb_rollback_on_timeout = 1
innodb_lock_wait_timeout   = 600
max_connections            = 350
log_bin_trust_function_creators = 1
expire_logs_days           = 7
character-set-server       = utf8mb4
collation-server           = utf8mb4_unicode_ci
