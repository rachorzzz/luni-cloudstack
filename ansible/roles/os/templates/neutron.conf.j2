[DEFAULT]
core_plugin = ml2
service_plugins = ovn-router
transport_url = rabbit://openstack:{{ rabbit_pass }}@{{ wg_ip }}:5672/
auth_strategy = keystone
notify_nova_on_port_status_changes = true
notify_nova_on_port_data_changes = true

[database]
connection = mysql+pymysql://neutron:{{ neutron_db_pass }}@{{ wg_ip }}/neutron

[keystone_authtoken]
www_authenticate_uri  = http://{{ wg_ip }}:5000
auth_url              = http://{{ wg_ip }}:5000
memcached_servers     = {{ wg_ip }}:11211
auth_type             = password
project_domain_name   = Default
user_domain_name      = Default
project_name          = service
username              = neutron
password              = {{ neutron_pass }}

[nova]
auth_url            = http://{{ wg_ip }}:5000
auth_type           = password
project_domain_name = Default
user_domain_name    = Default
region_name         = RegionOne
project_name        = service
username            = nova
password            = {{ nova_pass }}

[oslo_concurrency]
lock_path = /var/lib/neutron/tmp
