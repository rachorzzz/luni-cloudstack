[DEFAULT]
transport_url = rabbit://openstack:{{ rabbit_pass }}@{{ wg_ip }}:5672/
my_ip = {{ wg_ip }}
log_dir = /var/log/nova

[api_database]
connection = mysql+pymysql://nova:{{ nova_db_pass }}@{{ wg_ip }}/nova_api

[database]
connection = mysql+pymysql://nova:{{ nova_db_pass }}@{{ wg_ip }}/nova

[api]
auth_strategy = keystone

[keystone_authtoken]
www_authenticate_uri  = http://{{ wg_ip }}:5000/
auth_url              = http://{{ wg_ip }}:5000/
memcached_servers     = {{ wg_ip }}:11211
auth_type             = password
project_domain_name   = Default
user_domain_name      = Default
project_name          = service
username              = nova
password              = {{ nova_pass }}

[vnc]
enabled = true
server_listen = {{ wg_ip }}
server_proxyclient_address = {{ wg_ip }}

[glance]
api_servers = http://{{ wg_ip }}:9292

[oslo_concurrency]
lock_path = /var/lib/nova/tmp

[placement]
region_name         = RegionOne
project_domain_name = Default
project_name        = service
auth_type           = password
user_domain_name    = Default
auth_url            = http://{{ wg_ip }}:5000/v3
username            = placement
password            = {{ placement_pass }}

[neutron]
auth_url            = http://{{ wg_ip }}:5000
auth_type           = password
project_domain_name = Default
user_domain_name    = Default
region_name         = RegionOne
project_name        = service
username            = neutron
password            = {{ neutron_pass }}
